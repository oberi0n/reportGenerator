<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="analytic" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="22" bottomMargin="22" uuid="3e1487ad-6d65-44f7-99e2-9a7f57166af8">
    <parameter name="report" class="com.example.reportgenerator.model.LabReport"/>
    <parameter name="patient" class="com.example.reportgenerator.model.Patient"/>
    <parameter name="physician" class="com.example.reportgenerator.model.Physician"/>
    <parameter name="footerText" class="java.lang.String"/>
    <parameter name="logoImage" class="java.lang.Object"/>
    <field name="sectionHeader" class="java.lang.Boolean"/>
    <field name="sectionTitle" class="java.lang.String"/>
    <field name="displayLabel" class="java.lang.String"/>
    <field name="alarmSymbol" class="java.lang.String"/>
    <field name="resultValue" class="java.lang.String"/>
    <field name="unit" class="java.lang.String"/>
    <field name="referenceValue" class="java.lang.String"/>
    <field name="precedingValue" class="java.lang.String"/>
    <field name="resultComments" class="java.lang.String"/>
    <title>
        <band height="142">
            <image onErrorType="Blank"><reportElement x="0" y="0" width="250" height="50"/><imageExpression><![CDATA[$P{logoImage}]]></imageExpression></image>
            <staticText><reportElement x="350" y="6" width="185" height="18"/><textElement textAlignment="Right"><font size="12" isBold="true"/></textElement><text><![CDATA[Compte-rendu d'analyses]]></text></staticText>
            <textField><reportElement x="350" y="28" width="185" height="14"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA["Réf. " + $P{report}.referenceNumber()]]></textFieldExpression></textField>
            <line><reportElement x="0" y="58" width="535" height="1" forecolor="#1D2A7A"/></line>

            <rectangle><reportElement x="0" y="70" width="258" height="58" backcolor="#F8FAFE"/><graphicElement><pen lineColor="#B7C3D0"/></graphicElement></rectangle>
            <staticText><reportElement x="8" y="76" width="90" height="13" forecolor="#1D2A7A"/><textElement><font size="9" isBold="true"/></textElement><text><![CDATA[Patient]]></text></staticText>
            <textField><reportElement x="8" y="92" width="240" height="14"/><textElement><font size="10" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{patient}.firstName() + " " + $P{patient}.lastName()]]></textFieldExpression></textField>
            <textField><reportElement x="8" y="108" width="240" height="11"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA["Né(e): " + $P{patient}.birthdate() + "  Sexe: " + $P{patient}.sex()]]></textFieldExpression></textField>
            <textField><reportElement x="8" y="120" width="240" height="11"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA["ID: " + $P{patient}.internalId() + "  SSN: " + $P{patient}.ssn()]]></textFieldExpression></textField>

            <rectangle><reportElement x="277" y="70" width="258" height="58" backcolor="#F8FAFE"/><graphicElement><pen lineColor="#B7C3D0"/></graphicElement></rectangle>
            <staticText><reportElement x="285" y="76" width="120" height="13" forecolor="#1D2A7A"/><textElement><font size="9" isBold="true"/></textElement><text><![CDATA[Médecin]]></text></staticText>
            <textField><reportElement x="285" y="92" width="240" height="14"/><textElement><font size="10" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{physician}.fullName()]]></textFieldExpression></textField>
            <textField><reportElement x="285" y="108" width="240" height="11"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$P{physician}.organisationName() + " (" + $P{physician}.organisationId() + ")"]]></textFieldExpression></textField>
            <textField><reportElement x="285" y="120" width="240" height="11"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA["Code: " + $P{physician}.codeUcm()]]></textFieldExpression></textField>
        </band>
    </title>
    <pageHeader>
        <band height="34">
            <textField><reportElement x="0" y="0" width="275" height="12"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA["Prélèvement: " + $P{report}.prelevementDate() + "   Spécimen: " + $P{report}.specimenDate()]]></textFieldExpression></textField>
            <textField><reportElement x="285" y="0" width="250" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA["Validation: " + $P{report}.validationDate() + "   Statut: " + $P{report}.examinationStatus()]]></textFieldExpression></textField>
            <line><reportElement x="0" y="18" width="535" height="1" forecolor="#1D2A7A"/></line>
            <staticText><reportElement x="0" y="21" width="210" height="12" forecolor="#1D2A7A"/><textElement><font size="9" isBold="true"/></textElement><text><![CDATA[Analyse]]></text></staticText>
            <staticText><reportElement x="214" y="21" width="42" height="12" forecolor="#1D2A7A"/><textElement textAlignment="Right"><font size="9" isBold="true"/></textElement><text><![CDATA[Résultat]]></text></staticText>
            <staticText><reportElement x="262" y="21" width="45" height="12" forecolor="#1D2A7A"/><textElement><font size="9" isBold="true"/></textElement><text><![CDATA[Unité]]></text></staticText>
            <staticText><reportElement x="312" y="21" width="82" height="12" forecolor="#1D2A7A"/><textElement><font size="9" isBold="true"/></textElement><text><![CDATA[Référence]]></text></staticText>
            <staticText><reportElement x="400" y="21" width="52" height="12" forecolor="#1D2A7A"/><textElement><font size="9" isBold="true"/></textElement><text><![CDATA[Antérieur]]></text></staticText>
            <staticText><reportElement x="458" y="21" width="77" height="12" forecolor="#1D2A7A"/><textElement><font size="9" isBold="true"/></textElement><text><![CDATA[Commentaire]]></text></staticText>
        </band>
    </pageHeader>
    <detail>
        <band height="19" splitType="Stretch">
            <rectangle><reportElement x="0" y="0" width="535" height="17" backcolor="#E9EEF8"><printWhenExpression><![CDATA[$F{sectionHeader}]]></printWhenExpression></reportElement><graphicElement><pen lineColor="#D3DDED"/></graphicElement></rectangle>
            <textField><reportElement x="5" y="2" width="525" height="12" forecolor="#1D2A7A"><printWhenExpression><![CDATA[$F{sectionHeader}]]></printWhenExpression></reportElement><textElement><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{sectionTitle}]]></textFieldExpression></textField>

            <textField textAdjust="StretchHeight"><reportElement x="0" y="2" width="205" height="12"><printWhenExpression><![CDATA[!$F{sectionHeader}]]></printWhenExpression></reportElement><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{displayLabel}]]></textFieldExpression></textField>
            <textField><reportElement x="208" y="2" width="10" height="12" forecolor="#CC0000"><printWhenExpression><![CDATA[!$F{sectionHeader}]]></printWhenExpression></reportElement><textElement textAlignment="Center"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{alarmSymbol}]]></textFieldExpression></textField>
            <textField><reportElement x="220" y="2" width="36" height="12"><printWhenExpression><![CDATA[!$F{sectionHeader}]]></printWhenExpression></reportElement><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{resultValue}]]></textFieldExpression></textField>
            <textField><reportElement x="262" y="2" width="45" height="12"><printWhenExpression><![CDATA[!$F{sectionHeader}]]></printWhenExpression></reportElement><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{unit}]]></textFieldExpression></textField>
            <textField><reportElement x="312" y="2" width="82" height="12"><printWhenExpression><![CDATA[!$F{sectionHeader}]]></printWhenExpression></reportElement><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{referenceValue}]]></textFieldExpression></textField>
            <textField><reportElement x="400" y="2" width="52" height="12"><printWhenExpression><![CDATA[!$F{sectionHeader}]]></printWhenExpression></reportElement><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{precedingValue}]]></textFieldExpression></textField>
            <textField textAdjust="StretchHeight"><reportElement x="458" y="2" width="77" height="12"><printWhenExpression><![CDATA[!$F{sectionHeader}]]></printWhenExpression></reportElement><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{resultComments}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="18" width="535" height="1" forecolor="#E0E0E0"/></line>
        </band>
    </detail>
    <pageFooter>
        <band height="20">
            <line><reportElement x="0" y="0" width="535" height="1" forecolor="#B7C3D0"/></line>
            <staticText><reportElement x="0" y="5" width="290" height="12" forecolor="#666666"/><textElement><font size="8"/></textElement><text><![CDATA[Laboratoires Réunis - ISO 15189 - document généré automatiquement]]></text></staticText>
            <textField><reportElement x="435" y="5" width="100" height="12" forecolor="#666666"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression></textField>
        </band>
    </pageFooter>
    <summary>
        <band height="78" splitType="Stretch">
            <rectangle><reportElement x="0" y="0" width="535" height="31" backcolor="#FFF7E6"/><graphicElement><pen lineColor="#E0B35A"/></graphicElement></rectangle>
            <textField><reportElement x="8" y="6" width="519" height="12"/><textElement><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA["Total résultats: " + $P{report}.resultCount() + "  |  Résultats hors référence: " + $P{report}.abnormalResultCount() + "  |  Sections: " + String.join(", ", $P{report}.sections())]]></textFieldExpression></textField>
            <textField><reportElement x="8" y="19" width="519" height="10"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$P{report}.recordComments()]]></textFieldExpression></textField>
            <textField textAdjust="StretchHeight"><reportElement x="0" y="40" width="535" height="30"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$P{footerText}]]></textFieldExpression></textField>
        </band>
    </summary>
</jasperReport>
