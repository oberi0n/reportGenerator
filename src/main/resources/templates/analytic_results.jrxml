<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="analytic" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="24" bottomMargin="24" uuid="3e1487ad-6d65-44f7-99e2-9a7f57166af8">
    <parameter name="report" class="com.example.reportgenerator.model.LabReport"/>
    <parameter name="patient" class="com.example.reportgenerator.model.Patient"/>
    <parameter name="physician" class="com.example.reportgenerator.model.Physician"/>
    <parameter name="resultsTable" class="java.lang.String"/>
    <parameter name="footerText" class="java.lang.String"/>
    <title>
        <band height="166">
            <rectangle><reportElement x="0" y="0" width="535" height="54" backcolor="#F4F7FB"/><graphicElement><pen lineColor="#1D2A7A" lineWidth="1.0"/></graphicElement></rectangle>
            <staticText><reportElement x="14" y="10" width="330" height="26" forecolor="#1D2A7A"/><textElement><font size="21" isBold="true"/></textElement><text><![CDATA[LABORATOIRES RÉUNIS]]></text></staticText>
            <staticText><reportElement x="350" y="12" width="170" height="18"/><textElement textAlignment="Right"><font size="11" isBold="true"/></textElement><text><![CDATA[Compte-rendu d'analyses]]></text></staticText>
            <textField><reportElement x="350" y="32" width="170" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA["Réf. " + $P{report}.referenceNumber()]]></textFieldExpression></textField>

            <rectangle><reportElement x="0" y="66" width="260" height="82"/><graphicElement><pen lineColor="#B7C3D0"/></graphicElement></rectangle>
            <staticText><reportElement x="10" y="72" width="90" height="15" forecolor="#1D2A7A"/><textElement><font size="10" isBold="true"/></textElement><text><![CDATA[Patient]]></text></staticText>
            <textField><reportElement x="10" y="90" width="240" height="16"/><textElement><font size="11" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{patient}.firstName() + " " + $P{patient}.lastName()]]></textFieldExpression></textField>
            <textField><reportElement x="10" y="108" width="240" height="14"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA["Né(e): " + $P{patient}.birthdate() + "  Sexe: " + $P{patient}.sex()]]></textFieldExpression></textField>
            <textField><reportElement x="10" y="124" width="240" height="14"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA["ID: " + $P{patient}.internalId() + "  SSN: " + $P{patient}.ssn()]]></textFieldExpression></textField>

            <rectangle><reportElement x="275" y="66" width="260" height="82"/><graphicElement><pen lineColor="#B7C3D0"/></graphicElement></rectangle>
            <staticText><reportElement x="285" y="72" width="110" height="15" forecolor="#1D2A7A"/><textElement><font size="10" isBold="true"/></textElement><text><![CDATA[Médecin destinataire]]></text></staticText>
            <textField><reportElement x="285" y="90" width="240" height="16"/><textElement><font size="11" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{physician}.fullName()]]></textFieldExpression></textField>
            <textField><reportElement x="285" y="108" width="240" height="14"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$P{physician}.organisationName() + " (" + $P{physician}.organisationId() + ")"]]></textFieldExpression></textField>
            <textField><reportElement x="285" y="124" width="240" height="14"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA["Code: " + $P{physician}.codeUcm()]]></textFieldExpression></textField>
        </band>
    </title>
    <pageHeader>
        <band height="42">
            <textField><reportElement x="0" y="0" width="260" height="14"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA["Prélèvement: " + $P{report}.prelevementDate() + "   Spécimen: " + $P{report}.specimenDate()]]></textFieldExpression></textField>
            <textField><reportElement x="275" y="0" width="260" height="14"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA["Validation: " + $P{report}.validationDate() + "   Statut: " + $P{report}.examinationStatus()]]></textFieldExpression></textField>
            <line><reportElement x="0" y="24" width="535" height="1" forecolor="#1D2A7A"/></line>
            <staticText><reportElement x="0" y="28" width="535" height="14" forecolor="#1D2A7A"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[Résultats d'analyses]]></text></staticText>
        </band>
    </pageHeader>
    <detail>
        <band height="448" splitType="Stretch">
            <textField isStretchWithOverflow="true"><reportElement x="0" y="0" width="535" height="430"/><textElement markup="none"><font fontName="Monospaced" size="8"/></textElement><textFieldExpression><![CDATA[$P{resultsTable}]]></textFieldExpression></textField>
        </band>
    </detail>
    <summary>
        <band height="116" splitType="Stretch">
            <rectangle><reportElement x="0" y="0" width="535" height="38" backcolor="#FFF7E6"/><graphicElement><pen lineColor="#E0B35A"/></graphicElement></rectangle>
            <textField><reportElement x="8" y="7" width="519" height="14"/><textElement><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA["Total résultats: " + $P{report}.resultCount() + "  |  Résultats hors référence: " + $P{report}.abnormalResultCount() + "  |  Sections: " + String.join(", ", $P{report}.sections())]]></textFieldExpression></textField>
            <textField><reportElement x="8" y="22" width="519" height="12"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$P{report}.recordComments()]]></textFieldExpression></textField>
            <textField isStretchWithOverflow="true"><reportElement x="0" y="48" width="535" height="50"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$P{footerText}]]></textFieldExpression></textField>
        </band>
    </summary>
    <pageFooter>
        <band height="20">
            <line><reportElement x="0" y="0" width="535" height="1" forecolor="#B7C3D0"/></line>
            <staticText><reportElement x="0" y="5" width="260" height="12" forecolor="#666666"/><textElement><font size="8"/></textElement><text><![CDATA[Laboratoires Réunis - document généré automatiquement]]></text></staticText>
            <textField><reportElement x="435" y="5" width="100" height="12" forecolor="#666666"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression></textField>
        </band>
    </pageFooter>
</jasperReport>
