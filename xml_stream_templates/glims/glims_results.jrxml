<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="labo-lu-report" pageWidth="545" pageHeight="45" columnWidth="545" leftMargin="0"
              rightMargin="0" topMargin="0" bottomMargin="0" isFloatColumnFooter="true">
  <property name="net.sf.jasperreports.export.pdfa.conformance" value="pdfa1a"/>
  <property name="net.sf.jasperreports.export.pdfa.icc.profile.path" value="sRGB.icc"/>
  <property name="net.sf.jasperreports.default.pdf.embedded" value="true"/>
  <property name="net.sf.jasperreports.export.pdf.tagged" value="true"/>
  <property name="net.sf.jasperreports.export.pdf.tag.language" value="en-us"/>
  <import value="org.apache.commons.lang3.StringUtils"/>
  <style name="default" isDefault="true" fontName="ReportSourceSans3" fontSize="8.5"/>
  <style name="header" style="default" forecolor="#1961AC" fontSize="9.5">
    <conditionalStyle>
      <conditionExpression><![CDATA[$V{isSectionHeader}]]></conditionExpression>
      <style isBold="true"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA[$F{titleLevel}.equals("1")]]></conditionExpression>
      <style fontSize="12"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA[StringUtils.isNotEmpty($F{titleLevel})]]></conditionExpression>
      <style fontSize="10.5"/>
    </conditionalStyle>
  </style>
  <style name="zebra">
    <conditionalStyle>
      <conditionExpression><![CDATA[StringUtils.isNotEmpty($F{titleLevel})]]></conditionExpression>
      <style mode="Opaque" backcolor="#E6E6E6"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA[$V{darkBand}]]></conditionExpression>
      <style mode="Opaque" backcolor="#F4F5FB"/>
    </conditionalStyle>
  </style>
  <style name="layoutAnalyseIndent" style="header">
    <conditionalStyle>
      <conditionExpression><![CDATA["true".equals($F{layoutAnalyseIndent})]]></conditionExpression>
      <style>
        <box leftPadding="15"/>
      </style>
    </conditionalStyle>
  </style>
  <style name="newSection" style="header">
    <conditionalStyle>
      <conditionExpression><![CDATA[$V{newSection}]]></conditionExpression>
      <style>
        <box topPadding="12" bottomPadding="2"/>
      </style>
    </conditionalStyle>
  </style>
  <style name="textItem" style="default" mode="Transparent" forecolor="#1961AC" fontSize="8.5"/>
  <style name="pdfHeader" style="default" mode="Opaque" forecolor="#1961AC" pattern=""/>
  <style name="columnHeader" style="default" mode="Transparent" forecolor="#FF0000" fontSize="8.5"/>
  <style name="borderLine" forecolor="#1961AC"/>
  <style name="groupHeader" style="default" forecolor="#FFFFFF" backcolor="#BABABA" isBold="true"/>
  <style name="isolationRes" style="default" mode="Opaque" forecolor="#FFFFFF" backcolor="#8D93B4" hTextAlign="Center" fontSize="7" isBold="true"/>
  <style name="resultComment" style="default" forecolor="#165799" fontName="ReportHackMono" fontSize="7.5"/>
  <style name="bold" style="textItem" isBold="true"/>
  <style name="boldResult" style="textItem">
    <box leftPadding="183" rightPadding="218"/>
    <conditionalStyle>
      <conditionExpression><![CDATA["2".equals($F{display})]]></conditionExpression>
      <style>
        <box leftPadding="0" rightPadding="0"/>
      </style>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA["2".equals($F{display}) && StringUtils.isNotEmpty($F{resultValueText}) && $P{Util_SCRIPTLET}.isDigit($F{resultValueText})]]></conditionExpression>
      <style isBold="true"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA[!"2".equals($F{display})]]></conditionExpression>
      <style isBold="true"/>
    </conditionalStyle>
  </style>
  <style name="refItem" style="textItem" fontSize="8.5">
    <conditionalStyle>
      <conditionExpression><![CDATA[!$V{drawScale}]]></conditionExpression>
      <style>
        <box topPadding="4"/>
      </style>
    </conditionalStyle>
  </style>
  <subDataset name="TableDataset">
    <field name="0" class="java.lang.String"/>
    <field name="1" class="java.lang.String"/>
    <field name="background" class="java.lang.Boolean"/>
    <field name="header" class="java.lang.String"/>
    <field name="footer" class="java.lang.String"/>
  </subDataset>
  <scriptlet name="Util" class="lu.labo.Util"/>
  <scriptlet name="Scale" class="lu.labo.ImageController"/>
  <scriptlet name="GlimsGraph" class="lu.labo.GlimsGraphXml"/>
  <parameter name="report_chart_url" class="java.lang.String">
    <defaultValueExpression><![CDATA["http://localhost:8080/chart"]]></defaultValueExpression>
  </parameter>
  <parameter name="pdf" class="java.lang.Boolean">
    <defaultValueExpression><![CDATA[false]]></defaultValueExpression>
  </parameter>
  <parameter name="referenceNumber" class="java.lang.String"/>
  <parameter name="language" class="java.lang.String">
    <defaultValueExpression><![CDATA["en"]]></defaultValueExpression>
  </parameter>
  <parameter name="prelevementDate" class="java.lang.String"/>
  <parameter name="results" class="java.util.List"/>
  <parameter name="resultCount" class="java.lang.Integer"/>
  <parameter name="paramMap" class="java.util.Map" isForPrompting="false">
    <defaultValueExpression><![CDATA[new HashMap()]]></defaultValueExpression>
  </parameter>
  <parameter name="antibioGroupCount" class="java.lang.Integer"/>
  <parameter name="antibioResultCount" class="java.lang.Integer"/>
  <parameter name="antibioResults" class="java.util.Map"/>
  <queryString>
    <![CDATA[]]>
  </queryString>
  <field name="analyseName" class="java.lang.String"/>
  <field name="precedingValue" class="java.lang.String"/>
  <field name="referenceMax" class="java.lang.String"/>
  <field name="referenceMin" class="java.lang.String"/>
  <field name="referenceValue" class="java.lang.String"/>
  <field name="resultValue" class="java.lang.String"/>
  <field name="resultValueEn" class="java.lang.String"/>
  <field name="resultValueDe" class="java.lang.String"/>
  <field name="resultValueFr" class="java.lang.String"/>
  <field name="resultChoiceValue" class="java.lang.String"/>
  <field name="resultValueText" class="java.lang.String"/>
  <field name="title" class="java.lang.String"/>
  <field name="titleLevel" class="java.lang.String"/>
  <field name="type" class="java.lang.String"/>
  <field name="unit" class="java.lang.String"/>
  <field name="precedingDate" class="java.lang.String"/>
  <field name="resultComments" class="java.lang.String"/>
  <field name="layoutFormat" class="java.lang.String"/>
  <field name="layoutAnalyseIndent" class="java.lang.String"/>
  <field name="layoutCommentStructure" class="java.lang.String"/>
  <field name="subId" class="java.lang.String"/>
  <field name="analyseCode" class="java.lang.String"/>
  <field name="_id" class="java.util.UUID"/>
  <field name="resultHeaderGroup" class="java.lang.Integer"/>
  <field name="glimsGraphData" class="java.lang.String"/>
  <field name="display" class="java.lang.String"/>
  <field name="antibiogram" class="java.lang.String"/>
  <field name="prozent" class="java.lang.String"/>
  <field name="alarm" class="java.lang.String"/>
  <field name="antibioBlockNr" class="java.lang.Integer"/>
  <field name="hidden" class="java.lang.Boolean"/>
  <variable name="darkBand" class="java.lang.Boolean">
    <variableExpression><![CDATA[$V{REPORT_COUNT}.intValue() % 2 == 1]]></variableExpression>
  </variable>
  <variable name="isSectionHeader" class="java.lang.Boolean">
    <variableExpression><![CDATA["Title".equals($F{type})]]></variableExpression>
  </variable>
  <variable name="antibioResult" class="java.lang.Boolean">
    <variableExpression><![CDATA["AntibioResult".equals($F{type})]]></variableExpression>
  </variable>
  <variable name="isolationRes" class="java.lang.Boolean">
    <variableExpression><![CDATA["Isolation".equals($F{type})]]></variableExpression>
  </variable>
  <variable name="showHistory" class="java.lang.Boolean">
    <variableExpression><![CDATA[!$P{pdf} && $P{Util_SCRIPTLET}.isDigit($F{precedingValue}) && $P{Util_SCRIPTLET}.isDigit($F{resultValue})]]></variableExpression>
  </variable>
  <variable name="historyUrlParams" class="java.lang.String">
    <variableExpression><![CDATA[$V{showHistory} ? ("?resVal=" + $F{resultValue} + "&prVal=" + $F{precedingValue}+ "&refMin=" + $F{referenceMin}+ "&refMax=" + $F{referenceMax}  + "&date=" + $P{prelevementDate} + "&prDate=" + $F{precedingDate} + "&language=" + $P{language} + "&analyseName=" + $F{analyseName}) : null]]></variableExpression>
  </variable>
  <variable name="newSection" class="java.lang.Boolean">
    <variableExpression><![CDATA[!$V{isolationRes} && "1".equals($F{titleLevel}) && $V{REPORT_COUNT}.intValue()>1]]></variableExpression>
  </variable>
  <variable name="halfScale" class="java.lang.Boolean">
    <variableExpression><![CDATA[$F{referenceValue} !=null && ($F{referenceValue}.contains("<") || $F{referenceValue}.contains(">"))]]></variableExpression>
  </variable>
  <variable name="subIdsArray" class="java.lang.String" calculation="Sum">
    <variableExpression><![CDATA[($V{isolationRes} && "1".equals($F{subId})) ? (!"0".equals($F{antibiogram})? $F{subId} : "") : $V{subIdsArray} + ($V{isolationRes} && !"0".equals($F{antibiogram})? (StringUtils.isNotEmpty($V{subIdsArray}) ? "," : "") + $F{subId} : "")]]></variableExpression>
    <initialValueExpression><![CDATA[""]]></initialValueExpression>
  </variable>
  <variable name="resultValueTranslation" class="java.lang.String">
    <variableExpression><![CDATA[StringUtils.isEmpty($P{language}.equalsIgnoreCase("en")?$F{resultValueEn}:($P{language}.equalsIgnoreCase("de")?$F{resultValueDe}:$F{resultValueFr}))?$F{resultValue}:$P{language}.equalsIgnoreCase("en")?$F{resultValueEn}:($P{language}.equalsIgnoreCase("de")?$F{resultValueDe}:$F{resultValueFr})]]></variableExpression>
  </variable>
  <variable name="drawScale" class="java.lang.Boolean">
    <variableExpression><![CDATA[$F{resultValue} != null && $P{Util_SCRIPTLET}.isDigitOrPow($F{resultValue}) && ((StringUtils.isNotEmpty($F{referenceValue}) && $F{referenceValue}.contains("-")) || $P{Util_SCRIPTLET}.isDigitOrPow($F{referenceMax}) || $P{Util_SCRIPTLET}.isDigitOrPow($F{referenceMin}))]]></variableExpression>
  </variable>
  <group name="AnalyseClass" keepTogether="true">
    <groupExpression><![CDATA[$P{antibioResultCount}>0 ? 0 : ($F{resultHeaderGroup} != null ? $F{resultHeaderGroup} : Math.random())]]></groupExpression>
  </group>
  <background>
    <band splitType="Stretch"/>
  </background>
  <detail>
    <band height="15" splitType="Stretch">
      <printWhenExpression><![CDATA[!$V{antibioResult} && !"AntibioTitle".equals($F{type}) && !$V{isolationRes} && !$F{hidden}]]></printWhenExpression>
      <frame>
        <reportElement style="zebra" stretchType="ContainerHeight" mode="Opaque" x="0" y="0" width="545" height="15"/>
        <box>
          <pen lineWidth="0.0" lineStyle="Solid" lineColor="#1961AC"/>
          <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
          <leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#1961AC"/>
          <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
          <rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#1961AC"/>
        </box>
        <line>
          <reportElement style="borderLine" x="0" y="0" width="545" height="1">
            <printWhenExpression><![CDATA[$V{REPORT_COUNT}.intValue()==1 && $P{resultCount}==0]]></printWhenExpression>
          </reportElement>
          <graphicElement>
            <pen lineWidth="0.5"/>
          </graphicElement>
        </line>
        <rectangle>
          <reportElement x="0" y="0" width="545" height="12" forecolor="#FFFFFF">
            <printWhenExpression><![CDATA[$V{newSection}]]></printWhenExpression>
          </reportElement>
          <graphicElement>
            <pen lineWidth="0.5"/>
          </graphicElement>
        </rectangle>
        <textField textAdjust="StretchHeight" isBlankWhenNull="true">
          <reportElement style="newSection" stretchType="RelativeToBandHeight" x="7" y="2" width="515" height="13">
            <printWhenExpression><![CDATA[$V{isSectionHeader}]]></printWhenExpression>
          </reportElement>
          <textFieldExpression><![CDATA[$F{title}.trim()]]></textFieldExpression>
        </textField>
        <textField textAdjust="StretchHeight" isBlankWhenNull="true">
          <reportElement style="layoutAnalyseIndent" x="7" y="3" width="166" height="16">
            <printWhenExpression><![CDATA[!$V{isSectionHeader} && !"GlimsGraph".equals($F{type}) && !("2".equals($F{display}) && StringUtils.isNotEmpty($F{resultValueText}))]]></printWhenExpression>
          </reportElement>
          <textElement markup="styled"/>
          <textFieldExpression><![CDATA[$P{Util_SCRIPTLET}.layoutFormat($F{analyseName},$F{layoutFormat})]]></textFieldExpression>
        </textField>
        <textField textAdjust="StretchHeight">
          <reportElement style="bold" stretchType="RelativeToTallestObject" x="7" y="3" width="220" height="16">
            <printWhenExpression><![CDATA[!$V{isolationRes} && !$V{isSectionHeader} && StringUtils.isEmpty($F{analyseName}) && StringUtils.isNotEmpty($F{resultValueText})]]></printWhenExpression>
          </reportElement>
          <textFieldExpression><![CDATA[$F{resultValueText}]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="bold" x="180" y="3" width="30" height="16">
            <printWhenExpression><![CDATA[!$V{antibioResult} && !$F{type}.equals("Isolation") && $P{Util_SCRIPTLET}.isDigit($F{resultValue})]]></printWhenExpression>
          </reportElement>
          <textElement textAlignment="Right"/>
          <textFieldExpression><![CDATA[$P{Util_SCRIPTLET}.intPart($F{resultValue})]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="bold" x="210" y="3" width="30" height="16">
            <printWhenExpression><![CDATA[!$V{antibioResult} && !$F{type}.equals("Isolation") && $P{Util_SCRIPTLET}.isDigit($F{resultValue})]]></printWhenExpression>
          </reportElement>
          <textElement textAlignment="Left"/>
          <textFieldExpression><![CDATA[$P{Util_SCRIPTLET}.decPart($F{resultValue})]]></textFieldExpression>
        </textField>
        <textField textAdjust="StretchHeight">
          <reportElement style="boldResult" x="7" y="3" width="531" height="16">
            <printWhenExpression><![CDATA[!$V{antibioResult} && !$F{type}.equals("Isolation") && !"GlimsGraph".equals($F{type}) && (StringUtils.isNotEmpty($F{resultValue}) || StringUtils.isNotEmpty($F{resultValueText})) && !$P{Util_SCRIPTLET}.isDigit($F{resultValue}) && (StringUtils.isNotEmpty($F{analyseName}) || StringUtils.isEmpty($F{resultValueText}))]]></printWhenExpression>
          </reportElement>
          <textElement textAlignment="Left" markup="styled"/>
          <textFieldExpression><![CDATA[StringUtils.isNotEmpty($F{resultValueText})?$F{resultValueText}:$P{Util_SCRIPTLET}.checkPow($F{resultValue})]]></textFieldExpression>
        </textField>
        <textField textAdjust="ScaleFont">
          <reportElement style="textItem" x="270" y="3" width="50" height="16"/>
          <textElement markup="styled"/>
          <textFieldExpression><![CDATA[$P{Util_SCRIPTLET}.getUnit($F{unit})+(StringUtils.isNotEmpty($F{prozent})?" ("+$F{prozent}+")":"")]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="refItem" x="336" y="0" width="30" height="16">
            <printWhenExpression><![CDATA[!$V{halfScale}]]></printWhenExpression>
          </reportElement>
          <textElement textAlignment="Right" verticalAlignment="Top" markup="styled"/>
          <textFieldExpression><![CDATA[$P{Util_SCRIPTLET}.refValueLeft($F{referenceValue})]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="refItem" x="366" y="0" width="80" height="16"/>
          <textElement textAlignment="Left" verticalAlignment="Top" markup="styled"/>
          <textFieldExpression><![CDATA[$P{Util_SCRIPTLET}.refValueRight($F{referenceValue})]]></textFieldExpression>
        </textField>
        <image vAlign="Bottom">
          <reportElement x="330" y="3" width="80" height="12">
            <printWhenExpression><![CDATA[$V{drawScale}]]></printWhenExpression>
          </reportElement>
          <imageExpression><![CDATA[$P{Scale_SCRIPTLET}.createScale($F{referenceMin},$F{referenceMax},(StringUtils.isNotEmpty($F{resultChoiceValue})?$F{resultChoiceValue}:$F{resultValue}), $F{referenceValue}, $V{halfScale}, $V{darkBand})]]></imageExpression>
        </image>
        <textField>
          <reportElement style="textItem" x="425" y="3" width="30" height="16">
            <printWhenExpression><![CDATA[$P{Util_SCRIPTLET}.isDigit($F{precedingValue}) && !"GlimsGraph".equals($F{type})]]></printWhenExpression>
          </reportElement>
          <textElement textAlignment="Right"/>
          <textFieldExpression><![CDATA[$P{Util_SCRIPTLET}.intPart($F{precedingValue})]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="textItem" x="455" y="3" width="50" height="16">
            <printWhenExpression><![CDATA[$P{Util_SCRIPTLET}.isDigit($F{precedingValue}) && !"GlimsGraph".equals($F{type})]]></printWhenExpression>
          </reportElement>
          <textElement textAlignment="Left"/>
          <textFieldExpression><![CDATA[$P{Util_SCRIPTLET}.decPart($F{precedingValue})]]></textFieldExpression>
        </textField>
        <textField textAdjust="StretchHeight">
          <reportElement style="textItem" x="410" y="3" width="70" height="16">
            <printWhenExpression><![CDATA[StringUtils.isNotEmpty($F{precedingValue}) && !$P{Util_SCRIPTLET}.isDigit($F{precedingValue}) && !"GlimsGraph".equals($F{type})]]></printWhenExpression>
          </reportElement>
          <textElement textAlignment="Left"/>
          <textFieldExpression><![CDATA[$F{precedingValue}]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="textItem" x="480" y="3" width="55" height="16">
            <printWhenExpression><![CDATA[!"GlimsGraph".equals($F{type})]]></printWhenExpression>
          </reportElement>
          <textFieldExpression><![CDATA[($F{precedingDate}!=null)?$P{Util_SCRIPTLET}.formatDate($F{precedingDate}):""]]></textFieldExpression>
        </textField>
        <image>
          <reportElement x="180" y="4" width="7" height="7">
            <printWhenExpression><![CDATA["+".equals($F{alarm})]]></printWhenExpression>
          </reportElement>
          <imageExpression><![CDATA["/images/arrow-up.svg"]]></imageExpression>
        </image>
        <image>
          <reportElement x="180" y="4" width="7" height="7">
            <printWhenExpression><![CDATA["-".equals($F{alarm})]]></printWhenExpression>
          </reportElement>
          <imageExpression><![CDATA["/images/arrow-down.svg"]]></imageExpression>
        </image>
        <!--
        <image hyperlinkType="Reference">
          <reportElement x="525" y="0" width="13" height="16">
            <printWhenExpression><![CDATA[$V{showHistory}]]></printWhenExpression>
          </reportElement>
          <box topPadding="2"/>
          <imageExpression><![CDATA["/images/history.svg"]]></imageExpression>
          <hyperlinkReferenceExpression><![CDATA["javascript:void(window.showReportChart('"+ $P{report_chart_url} + $V{historyUrlParams}  + "'));"]]></hyperlinkReferenceExpression>
        </image>
        -->
        <textField textAdjust="StretchHeight">
          <reportElement style="resultComment" positionType="Float" x="7" y="18" width="535" height="15" isRemoveLineWhenBlank="true">
            <printWhenExpression><![CDATA[!$V{isolationRes} && StringUtils.isNotEmpty($F{resultComments})]]></printWhenExpression>
          </reportElement>
          <box topPadding="0" leftPadding="0" bottomPadding="3" rightPadding="0"/>
          <textElement markup="none"/>
          <textFieldExpression><![CDATA[$F{resultComments}]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement x="336" y="4" width="120" height="11"/>
          <textFieldExpression><![CDATA[$P{paramMap}.put("subIdsArray", $V{subIdsArray})]]></textFieldExpression>
        </textField>
      </frame>
    </band>
    <band height="15" splitType="Stretch">
      <printWhenExpression><![CDATA[!$V{antibioResult} && !"AntibioTitle".equals($F{type}) && $V{isolationRes}]]></printWhenExpression>
      <frame>
        <reportElement style="zebra" stretchType="ContainerHeight" mode="Opaque" x="0" y="0" width="545" height="15"/>
        <box>
          <pen lineWidth="0.0" lineStyle="Solid" lineColor="#1961AC"/>
        </box>
        <textField>
          <reportElement style="isolationRes" x="200" y="3" width="11" height="11">
            <printWhenExpression><![CDATA[$V{isolationRes} && !"0".equals($F{antibiogram}) && $P{Util_SCRIPTLET}.showAntibioOrderNumber( $F{subId}, $V{subIdsArray}, 1 )]]></printWhenExpression>
          </reportElement>
          <textElement verticalAlignment="Middle"/>
          <textFieldExpression><![CDATA["1"]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="isolationRes" x="212" y="3" width="11" height="11">
            <printWhenExpression><![CDATA[$V{isolationRes} && !"0".equals($F{antibiogram}) && $P{Util_SCRIPTLET}.showAntibioOrderNumber( $F{subId}, $V{subIdsArray}, 2 )]]></printWhenExpression>
          </reportElement>
          <textElement verticalAlignment="Middle"/>
          <textFieldExpression><![CDATA["2"]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="isolationRes" x="224" y="3" width="11" height="11">
            <printWhenExpression><![CDATA[$V{isolationRes} && !"0".equals($F{antibiogram}) && $P{Util_SCRIPTLET}.showAntibioOrderNumber( $F{subId}, $V{subIdsArray}, 3 )]]></printWhenExpression>
          </reportElement>
          <textElement verticalAlignment="Middle"/>
          <textFieldExpression><![CDATA["3"]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="isolationRes" x="236" y="3" width="11" height="11">
            <printWhenExpression><![CDATA[$V{isolationRes} && !"0".equals($F{antibiogram}) && $P{Util_SCRIPTLET}.showAntibioOrderNumber( $F{subId}, $V{subIdsArray}, 4 )]]></printWhenExpression>
          </reportElement>
          <textElement verticalAlignment="Middle"/>
          <textFieldExpression><![CDATA["4"]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="isolationRes" x="248" y="3" width="11" height="11">
            <printWhenExpression><![CDATA[$V{isolationRes} && !"0".equals($F{antibiogram}) && $P{Util_SCRIPTLET}.showAntibioOrderNumber( $F{subId}, $V{subIdsArray}, 5 )]]></printWhenExpression>
          </reportElement>
          <textElement verticalAlignment="Middle"/>
          <textFieldExpression><![CDATA["5"]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="isolationRes" x="473" y="3" width="11" height="11">
            <printWhenExpression><![CDATA[$V{isolationRes} && !"0".equals($F{antibiogram}) && $P{Util_SCRIPTLET}.showAntibioOrderNumber( $F{subId}, $V{subIdsArray}, 1 )]]></printWhenExpression>
          </reportElement>
          <textElement verticalAlignment="Middle"/>
          <textFieldExpression><![CDATA["1"]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="isolationRes" x="485" y="3" width="11" height="11">
            <printWhenExpression><![CDATA[$V{isolationRes} && !"0".equals($F{antibiogram}) && $P{Util_SCRIPTLET}.showAntibioOrderNumber( $F{subId}, $V{subIdsArray}, 2 )]]></printWhenExpression>
          </reportElement>
          <textElement verticalAlignment="Middle"/>
          <textFieldExpression><![CDATA["2"]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="isolationRes" x="497" y="3" width="11" height="11">
            <printWhenExpression><![CDATA[$V{isolationRes} && !"0".equals($F{antibiogram}) && $P{Util_SCRIPTLET}.showAntibioOrderNumber( $F{subId}, $V{subIdsArray}, 3 )]]></printWhenExpression>
          </reportElement>
          <textElement verticalAlignment="Middle"/>
          <textFieldExpression><![CDATA["3"]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="isolationRes" x="509" y="3" width="11" height="11">
            <printWhenExpression><![CDATA[$V{isolationRes} && !"0".equals($F{antibiogram}) && $P{Util_SCRIPTLET}.showAntibioOrderNumber( $F{subId}, $V{subIdsArray}, 4 )]]></printWhenExpression>
          </reportElement>
          <textElement verticalAlignment="Middle"/>
          <textFieldExpression><![CDATA["4"]]></textFieldExpression>
        </textField>
        <textField>
          <reportElement style="isolationRes" x="521" y="3" width="11" height="11">
